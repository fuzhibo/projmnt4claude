{
  "version": "1.0.0",
  "defaultPriority": "P2",
  "taskIdPrefix": "TASK",
  "ai": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "maxTokens": 4000,
    "temperature": 0.7
