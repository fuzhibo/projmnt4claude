{
  "name": "projmnt4claude",
  "version": "1.28.1",
  "description": "Claude Code 项目管理 CLI 工具",
  "module": "src/index.ts",
  "main": "dist/projmnt4claude.js",
  "types": "src/index.ts",
  "type": "module",
  "bin": {
    "projmnt4claude": "./dist/projmnt4claude.js"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "build": "bun build src/index.ts --outfile dist/projmnt4claude.js --target node --minify",
    "build:plugin": "bun run build && cp -r dist skills commands .claude-plugin ./plugin-dist/",
    "prepublishOnly": "bun test --coverage && bun run build",
    "pre-commit": "bun test",
    "test": "bun test",
    "version:patch": "bash scripts/version-bump.sh patch",
    "version:minor": "bash scripts/version-bump.sh minor",
    "version:major": "bash scripts/version-bump.sh major",
    "sync-testmarketplace": "bash scripts/sync-testmarketplace.sh",
    "sync-marketplace": "bash scripts/sync-testmarketplace.sh",
    "release:patch": "bun run version:patch && bun run sync-testmarketplace",
    "release:minor": "bun run version:minor && bun run sync-testmarketplace",
    "release:major": "bun run version:major && bun run sync-testmarketplace"
  },
  "files": [
    "dist/",
    "skills/",
    "commands/",
    ".claude-plugin/",
    "README.md"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/prompts": "^2.4.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "prompts": "^2.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude-code",
    "project-management",
    "task-management",
    "cli",
    "subtask"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fuzhibo/projmnt4claude.git"
  }
}